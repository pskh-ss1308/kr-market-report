# =============================================
#  국내 증시 데일리 레포트 — 환경변수 설정 파일
# =============================================
# 이 파일을 복사해서 .env 로 저장 후 값을 채우세요.
# .env 는 절대 GitHub에 올리지 마세요 (.gitignore 처리됨).

# =============================================
#  PHASE 1: 시뮬레이션 (비용 0원)
#  KIS API / Claude API 키 없어도 실행됩니다.
# =============================================
SIMULATION_MODE=true

# =============================================
#  KIS OpenAPI — 수급·섹터 데이터 (공식 API)
#  한국투자증권 KIS Developers에서 발급
#  https://apiportal.koreainvestment.com
#  ⚠️ 절대 GitHub에 올리지 마세요
# =============================================
KIS_APP_KEY=
KIS_APP_SECRET=

# =============================================
#  PHASE 2: 실전 전환 시
#  SIMULATION_MODE=false 로 변경 + 아래 키 입력
# =============================================
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# =============================================
#  이메일 발송 (선택)
# =============================================
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=내Gmail주소@gmail.com
SMTP_PASS=Gmail앱비밀번호16자리
EMAIL_TO=받을이메일@gmail.com

# =============================================
#  Slack 발송 (선택)
# =============================================
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
